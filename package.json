{
  "name": "datainsights-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:backend": "cd backend-node && npm run dev",
    "dev:frontend": "cd frontend-react && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "install:all": "npm install && cd backend-node && npm install && cd ../frontend-react && npm install"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "recharts": "^3.8.1"
  }
}
